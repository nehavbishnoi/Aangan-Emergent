# Copy this file's contents into Render's environment variables dashboard.
# Do NOT commit a real .env file with secrets to GitHub.

# MongoDB Atlas connection string (free M0 cluster)
# Get this from Atlas -> Database -> Connect -> Drivers
MONGO_URL=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority

DB_NAME=aangan

# Any long random string — Render can auto-generate this for you
JWT_SECRET=change-this-to-a-long-random-string

# Your Vercel frontend URL once deployed, e.g. https://aangan.vercel.app
# Comma-separate multiple origins if needed.
CORS_ORIGINS=https://your-frontend.vercel.app

# Optional — leave blank to keep "Ask Aangan" AI chat disabled for now.
# Add later from console.anthropic.com when ready to enable it (pay-as-you-go, no markup).
ANTHROPIC_API_KEY=

# Optional — leave blank to keep voice transcription disabled for now.
# Add later from platform.openai.com when ready to enable it.
OPENAI_API_KEY=
